rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Fotos de tours/passeios
    match /tours/{tourId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Fotos de achados e perdidos
    match /lostAndFound/{itemId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Regra padrão - APENAS USUÁRIOS AUTENTICADOS
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}