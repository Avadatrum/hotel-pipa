rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Fotos de tours/passeios
    match /tours/{tourId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null && request.auth.token.admin == true;
    }
    
    // 🆕 Fotos de achados e perdidos
    match /lostAndFound/{itemId}/{fileName} {
      allow read: if true;  // Qualquer pessoa pode ver
      allow write: if request.auth != null;  // Usuários autenticados podem enviar
      allow delete: if request.auth != null;  // Usuários autenticados podem deletar
    }
    
    // Regra padrão para outras pastas
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
  }
}