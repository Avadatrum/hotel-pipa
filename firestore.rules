// firestore.rules - ÚLTIMA VERSÃO
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    match /apartments/{apartment} {
      allow read, write: if request.auth != null;
      
      match /towelSignatures/{token} {
        allow read: if true;  // Pública
        allow write: if true;  // 🆕 Permite escrita pública (REST API)
      }
    }
    
    match /log/{document} {
      allow read: if request.auth != null;
      allow create: if true;  // 🆕 Pública pode criar logs
      allow update, delete: if request.auth != null;
    }
    
    match /losses/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /serviceOrders/{order} {
      allow read, write: if request.auth != null;
    }
    
    match /lostAndFound/{item} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /tours/{tour} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /commissions/{commission} {
      allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}