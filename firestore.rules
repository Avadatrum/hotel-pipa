rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.role == 'admin';
    }
    
    // 🆕 Permite leitura pública para o guia do hóspede
    match /apartments/{apartment} {
      allow read: if true; // hóspede precisa ver toalhas/fichas
      allow write: if request.auth != null;
      
      match /towelSignatures/{token} {
        allow read: if true;
        allow write: if true;
      }
    }

    match /termSignatures/{token} {
      allow read: if true;
      allow write: if true;
    }
    
    // 🆕 Guia do Hóspede - Tokens
    match /guestTokens/{token} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
    
    // 🆕 Guia do Hóspede - Configurações
    match /config/guestGuide {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /log/{document} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    
    match /losses/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /serviceOrders/{order} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /lostAndFound/{item} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /tours/{tour} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 🆕 Taxi Requests
    match /taxiRequests/{request} {
      allow read: if true; // página pública precisa criar e ler status
      allow create: if true; // hóspede pode criar solicitação
      allow update: if request.auth != null; // só staff atende
    }
    
    match /sales/{sale} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /commissions/{commission} {
      allow read, write: if request.auth != null;
    }
    
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}