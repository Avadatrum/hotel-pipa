// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Verificar se usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Verificar se é admin (via custom claims)
    function isAdmin() {
      return request.auth != null && request.auth.token.isAdmin == true;
    }
    
    // ============ USERS ============
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin();
      allow delete: if isAdmin() && request.auth.uid != userId;
    }
    
    // ============ TOURS ============
    match /tours/{tourId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============ AGENCIES ============
    match /agencies/{agencyId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============ SALES ============
    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
        request.resource.data.vendedorId == request.auth.uid &&
        request.resource.data.status == 'confirmada';
      allow update: if isAdmin() || 
        (resource.data.vendedorId == request.auth.uid && 
         request.resource.data.diff(resource.data).affectedKeys.hasOnly(['status']));
      allow delete: if false; // Não permitir exclusão de vendas
    }
    
    // ============ CUSTOM COMMISSIONS ============
    match /customCommissions/{commissionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============ COMMISSION AUDIT ============
    match /commissionAudit/{auditId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============ APP SETTINGS ============
    match /appSettings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ============ SISTEMA EXISTENTE ============
    match /apartments/{aptId} {
      allow read, write: if isAuthenticated();
    }
    
    match /log/{logId} {
      allow read, write: if isAuthenticated();
    }
    
    match /losses/{lossId} {
      allow read, write: if isAuthenticated();
    }
    
    match /receipts/{receiptId} {
      allow read, write: if isAuthenticated();
    }
    
    match /documents/{docId} {
      allow read, write: if isAuthenticated();
    }
    
    match /config/{configId} {
      allow read, write: if isAuthenticated();
    }
  }
}